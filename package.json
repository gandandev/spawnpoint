{
  "name": "spawnpoint",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sh -c 'pids=$(lsof -ti tcp:3000 2>/dev/null); [ -z \"$pids\" ] || kill $pids; for i in $(seq 1 25); do [ -z \"$(lsof -ti tcp:3000 2>/dev/null)\" ] && [ -z \"$(lsof -ti tcp:25565 2>/dev/null)\" ] && break; sleep 1; done; lsof -ti tcp:3000 2>/dev/null | xargs kill -9 2>/dev/null || true; lsof -ti tcp:25565 2>/dev/null | xargs kill -9 2>/dev/null || true; exec tsx watch --env-file=.env server/index.ts'",
    "dev:client": "vite",
    "prebuild": "npm run prepare:clients && npm run generate:skins",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:plugin": "node scripts/build-plugin.mjs",
    "prepare:clients": "node scripts/prepare-clients.mjs",
    "generate:skins": "node scripts/generate-presets.mjs",
    "start": "node --env-file=.env dist/server/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@south-paw/typeface-minecraft": "^1.0.0",
    "better-sqlite3": "^12.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "express": "^5.1.0",
    "http-proxy": "^1.18.1",
    "lucide-react": "^0.536.0",
    "multer": "^2.0.2",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "shadcn": "^4.13.0",
    "sharp": "^0.34.3",
    "skin3d": "^0.1.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.156.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/http-proxy": "^1.17.16",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.17.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vite": "^8.0.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  }
}
