{
  "name": "spawnpoint",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "dev:client": "vite",
    "prebuild": "npm run prepare:clients && npm run generate:skins",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:plugin": "node scripts/build-plugin.mjs",
    "prepare:clients": "node scripts/prepare-clients.mjs",
    "generate:skins": "node scripts/generate-presets.mjs",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "cookie": "^1.0.2",
    "express": "^5.1.0",
    "http-proxy": "^1.18.1",
    "lucide-react": "^0.536.0",
    "multer": "^2.0.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/http-proxy": "^1.17.16",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.17.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^26.1.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vite": "^8.0.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  }
}
